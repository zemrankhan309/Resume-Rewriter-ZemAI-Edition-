{
  "manifest_version": 3,
  "name": "ZemAI Resume Rewriter + ATS Analyzer",
  "version": "1.0",
  "description": "Rewrite resumes, match job descriptions, and generate a full ATS analysis dashboard using Gemini.",

  "permissions": ["storage", "tabs"],

  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "ZemAI Resume Rewriter"
  },

  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "fullpage.html",
        "fullpage.css",
        "fullpage.js",
        "editor.html",
        "editor.css",
        "editor.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
